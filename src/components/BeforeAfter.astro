---
export interface Props {
  beforeImage?: string;
  afterImage?: string;
  beforeAlt?: string;
  afterAlt?: string;
  title?: string;
}

const {
  beforeImage = '/images/before-placeholder.jpg',
  afterImage = '/images/after-placeholder.jpg',
  beforeAlt = 'Avant intervention',
  afterAlt = 'Après intervention',
  title = 'Nos interventions',
} = Astro.props;
---

<div class="before-after">
  <h3 class="ba-title">{title}</h3>
  <div class="ba-grid">
    <div class="ba-card">
      <div class="ba-label ba-label-before">Avant</div>
      <div class="ba-image-placeholder" role="img" aria-label={beforeAlt}>
        <span>Photo avant intervention</span>
      </div>
    </div>
    <div class="ba-card">
      <div class="ba-label ba-label-after">Après</div>
      <div class="ba-image-placeholder ba-after" role="img" aria-label={afterAlt}>
        <span>Photo après intervention</span>
      </div>
    </div>
  </div>
</div>

<style>
  .before-after {
    margin-block: var(--space-xl);
  }

  .ba-title {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .ba-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 700px;
    margin-inline: auto;
  }

  .ba-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ba-label {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #fff;
    z-index: 1;
  }

  .ba-label-before {
    background-color: var(--color-error);
  }

  .ba-label-after {
    background-color: var(--color-success);
  }

  .ba-image-placeholder {
    aspect-ratio: 4/3;
    background-color: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .ba-after {
    background-color: #e8f5e9;
    border-color: var(--color-success);
  }
</style>
