---
const badges = [
  { icon: '🕐', text: '24h/24 — 7j/7' },
  { icon: '⚡', text: 'Intervention 30 min' },
  { icon: '📋', text: 'Devis gratuit' },
  { icon: '✅', text: 'Travaux garantis' },
  { icon: '⭐', text: '5/5 sur Google' },
];
---

<div class="trust-badges">
  {badges.map((badge) => (
    <div class="trust-badge">
      <span class="badge-icon" aria-hidden="true">{badge.icon}</span>
      <span class="badge-text">{badge.text}</span>
    </div>
  ))}
</div>

<style>
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .badge-icon {
    font-size: var(--text-base);
  }

  /* On light background variant */
  :global(.section:not(.section-dark)) .trust-badge,
  :global(.hero-badges-light) .trust-badge {
    background-color: #fff;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
</style>
